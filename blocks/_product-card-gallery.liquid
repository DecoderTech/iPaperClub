

{% assign has_applied_colour_filter = false %}
{% if collection.filters %}
  {% for filter in collection.filters %}
    {% if filter.type == 'list' and filter.param_name contains 'color' %}
      {% if filter.active_values.size > 0 %}
        {% assign has_applied_colour_filter = true %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}

{% capture children %}
  {% unless closest.product == blank %}
    {% render 'product-card-badges', product: closest.product %}
    {%  if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add', product: closest.product, section_id: section.id %}
    {% endif %}
  {% endunless %}
{% endcapture %}

{% liquid
  assign is_frame_product = false
  
  # Check product type (exact match)
  if closest.product.type == 'Quadro'
    assign is_frame_product = true
  endif

  # Check options: only if product has an option explicitly named 'Moldura'
  unless is_frame_product
    for option in closest.product.options_with_values
      assign option_name = option.name | downcase
      if option_name contains 'moldura'
        assign is_frame_product = true
        break
      endif
    endfor
  endunless
%}

{% if is_frame_product %}
  {% liquid
    assign target_media = closest.product.featured_media
    if target_media == blank and closest.product.media.size > 0
      assign target_media = closest.product.media.first
    endif
  %}
  {% if target_media != blank %}
    <div class="frame-preview frame-preview--white frame-preview--card">
      <div class="frame-preview__inner">
        {% render 'product-media', media: target_media, preview_image_only: true, loading: 'lazy' %}
      </div>
      <img
        class="frame-preview__frame-image"
        src="{{ 'moldura_white_fixed.png' | asset_url }}"
        alt=""
        loading="lazy"
      >
      {% if closest.product.media.size > 1 %}
        <div class="frame-preview__hover-media">
          {% render 'product-media', media: closest.product.media[1], preview_image_only: true, loading: 'lazy' %}
        </div>
      {% endif %}
    </div>
  {% endif %}
{% else %}
  {% render 'card-gallery', children: children, has_applied_colour_filter: has_applied_colour_filter %}
{% endif %}

{% # Title and price for the zoomed out grid view %}
<div class="product-grid-view-zoom-out--details">
  {% if closest.product == blank %}
    <h3 class="h4">{{ 'content.product_card_placeholder' | t }}</h3>
  {% else %}
    <h3 class="h4">{{ closest.product.title }}</h3>
    <div class="h6">
      <product-price data-product-id="{{ closest.product.id }}">
        {% render 'price', product_resource: closest.product, show_unit_price: false %}
      </product-price>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .frame-preview--card {
    position: relative;
    width: 100%;
    height: auto;
    aspect-ratio: 1200 / 1380;
    overflow: hidden;
    background-color: #ffffff;
  }

  .frame-preview--card .frame-preview__inner {
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    padding: 6.75% 11.33%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .frame-preview--card .frame-preview__inner .product-media {
    width: 100%;
    height: 100%;
    padding: 0;
    aspect-ratio: auto;
    overflow: hidden;
    max-width: 100%;
    max-height: 100%;
  }

  .frame-preview--card .frame-preview__inner .product-media__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    max-width: 100%;
    max-height: 100%;
  }

  .frame-preview--card .frame-preview__frame-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    object-fit: contain;
  }

  .frame-preview--card .frame-preview__hover-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
    background-color: #fff;
  }

  .frame-preview--card:hover .frame-preview__hover-media {
    opacity: 1;
  }

  .frame-preview--card .frame-preview__hover-media .product-media {
    width: 100%;
    height: 100%;
    padding: 0;
  }

  .frame-preview--card .frame-preview__hover-media .product-media__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_image",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "portrait",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card_media",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
